{
  "name": "bsv-bap",
  "version": "0.2.0",
  "description": "BAP npm module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BitcoinSchema/bap.git"
  },
  "license": "Open BSV",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.module.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "import": "./dist/index.modern.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "bap": "./src/cli.ts"
  },
  "files": [
    "dist/*.js",
    "dist/*.js.map",
    "dist/*.d.ts",
    "src/cli.ts",
    "src/touchid.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bun run clean && bun run build.ts",
    "clean": "rimraf ./dist",
    "test": "bun test",
    "check": "biome check .",
    "format": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.12.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@1sat/vault": "0.0.2",
    "commander": "^14.0.3",
    "schema-dts": "^1.1.5"
  },
  "peerDependencies": {
    "@bsv/sdk": "^2.0.1"
  },
  "trustedDependencies": [
    "@1sat/vault"
  ]
}
